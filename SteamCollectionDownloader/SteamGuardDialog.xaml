<Window x:Class="SteamDownloader.SteamGuardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Guard"
        Height="230" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Steam Guard code required"
                   FontSize="14"
                   FontWeight="SemiBold"
                   FontFamily="Segoe UI"
                   Foreground="#E0E0E0"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Text="Check your email or authenticator app and enter the code:"
                   FontSize="11"
                   FontFamily="Segoe UI"
                   Foreground="#B0BEC5"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <TextBox x:Name="CodeTextBox"
                 Grid.Row="2"
                 MaxLength="5"
                 CharacterCasing="Upper"
                 FontSize="32"
                 FontWeight="Bold"
                 FontFamily="Consolas"
                 Background="#2D2D2D"
                 Foreground="#FFFFFF"
                 CaretBrush="#FFFFFF"
                 BorderBrush="#039BE5"
                 BorderThickness="2"
                 Padding="10"
                 Height="60"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 VerticalAlignment="Center"
                 KeyDown="CodeTextBox_KeyDown"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="80"
                    Margin="0,0,5,0"
                    Background="#616161"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="8,4"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="80"
                    Background="#039BE5"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="8,4"
                    Cursor="Hand"
                    IsDefault="True"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
