<Window x:Class="SteamDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Collection Downloader" 
        Height="600" Width="800"
        MinHeight="250" MinWidth="350"
        Background="#1E1E1E"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">
    <Window.Resources>
        <!-- Style for Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#039BE5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#29B6F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0288D1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#616161"/>
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#616161"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#039BE5"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#616161"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for ProgressBar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#616161"/>
            <Setter Property="Foreground" Value="#00E5FF"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <Grid>
                                <Rectangle x:Name="PART_Indicator"
                                           HorizontalAlignment="Left"
                                           Fill="{TemplateBinding Foreground}"
                                           RadiusX="4" RadiusY="4"/>
                                <TextBlock x:Name="ProgressText"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, StringFormat={}{0:F1}%}"
                                           Foreground="White"
                                           FontSize="9"
                                           FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Steam Workshop Downloader"
                   FontSize="18"
                   FontWeight="SemiBold"
                   FontFamily="Segoe UI"
                   Foreground="#E0E0E0"
                   Margin="0,0,0,8"/>

        <!-- URL input -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Collection URL:"
                       Width="70"
                       FontSize="11"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"
                       Foreground="#B0BEC5"/>
            <TextBox x:Name="CollectionUrlTextBox"
                     Width="400"
                     Margin="5,0,0,0"
                     AcceptsReturn="False"
                     ToolTip="Enter the Steam Workshop collection URL"/>
        </StackPanel>

        <!-- Login section -->
        <Border Grid.Row="2"
                BorderBrush="#616161"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,8">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Login:"
                               Width="70"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Foreground="#B0BEC5"/>
                    <RadioButton x:Name="AnonymousRadio"
                                 Content="Anonymous"
                                 GroupName="LoginMode"
                                 IsChecked="True"
                                 Foreground="#E0E0E0"
                                 FontSize="11"
                                 FontFamily="Segoe UI"
                                 VerticalAlignment="Center"
                                 Margin="5,0,15,0"
                                 Checked="LoginMode_Changed"/>
                    <RadioButton x:Name="AccountRadio"
                                 Content="My Steam account"
                                 GroupName="LoginMode"
                                 Foreground="#E0E0E0"
                                 FontSize="11"
                                 FontFamily="Segoe UI"
                                 VerticalAlignment="Center"
                                 Checked="LoginMode_Changed"/>
                </StackPanel>
                <Grid x:Name="CredentialsPanel" Visibility="Collapsed" Margin="75,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Username:"
                               Width="70"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Foreground="#B0BEC5"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             x:Name="UsernameTextBox"
                             Width="250"
                             HorizontalAlignment="Left"
                             Margin="5,0,0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Password:"
                               Width="70"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Foreground="#B0BEC5"/>
                    <PasswordBox Grid.Row="1" Grid.Column="1"
                                 x:Name="PasswordBox"
                                 Width="250"
                                 HorizontalAlignment="Left"
                                 Margin="5,0,0,4"
                                 Background="#2D2D2D"
                                 Foreground="#E0E0E0"
                                 BorderBrush="#616161"
                                 BorderThickness="1"
                                 Padding="6"
                                 FontSize="11"
                                 FontFamily="Segoe UI"/>

                    <CheckBox Grid.Row="2" Grid.Column="1"
                              x:Name="RememberPasswordCheckBox"
                              Content="Remember password (DPAPI encrypted)"
                              Margin="5,4,0,0"
                              Foreground="#B0BEC5"
                              FontSize="11"
                              FontFamily="Segoe UI"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Log output -->
        <ListBox x:Name="LogListBox"
                 Grid.Row="3"
                 Margin="0,0,0,8"/>

        <!-- Progress section -->
        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock x:Name="StatusTextBlock"
                       Text="Ready"
                       FontSize="10"
                       FontFamily="Segoe UI"
                       Foreground="#B0BEC5"
                       Margin="0,0,0,3"/>
            <ProgressBar x:Name="DownloadProgressBar"
                         Maximum="100"
                         Value="0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="OpenFolderButton"
                    Content="Open Folder"
                    Width="80"
                    Margin="0,0,5,0"
                    ToolTip="Open the folder containing downloaded items"
                    Click="OpenFolderButton_Click"/>
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="80"
                    Margin="0,0,5,0"
                    ToolTip="Cancel the current download"
                    Click="CancelButton_Click"/>
            <Button x:Name="StartButton"
                    Content="Start download"
                    Width="90"
                    Background="Green"
                    Click="StartButton_Click"/>
        </StackPanel>
    </Grid>
</Window>